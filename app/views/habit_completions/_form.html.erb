<%= form_with(model: habit_completion) do |form| %>
  <% if habit_completion.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(habit_completion.errors.count, "error") %> prohibited this habit_completion from being saved:</h2>

      <ul>
        <% habit_completion.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :habit_id, style: "display: block" %>
    <%= form.text_field :habit_id %>
  </div>

  <div>
    <%= form.label :completion_date, style: "display: block" %>
    <%= form.datetime_field :completion_date %>
  </div>

  <div>
    <%= form.label :goal_type, style: "display: block" %>
    <%= form.number_field :goal_type %>
  </div>

  <div>
    <%= form.label :goal_amount, style: "display: block" %>
    <%= form.number_field :goal_amount %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
