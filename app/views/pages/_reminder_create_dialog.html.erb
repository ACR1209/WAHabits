<dialog data-reminder-dialog-target="dialog" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 hidden -translate-y-1/2 inset-0 items-center justify-center p-0 m-0 border-none bg-transparent">
    <div class="bg-white rounded-lg shadow-lg p-8 w-full max-w-md mx-auto">
        <%= form_with(model: Reminder.new, url: reminders_path, method: :post, data: { reminder_dialog_target: "form", action: "reminder-dialog#submitForm" }) do |form| %>
            <div class="mb-4">
                <%= form.label :title, class: "block mb-1 font-semibold" %>
                <%= form.text_field :title, class: "w-full border rounded px-2 py-1" %>
            </div>
            <div class="mb-4">
                <%= form.label :description, class: "block mb-1 font-semibold" %>
                <%= form.text_field :description, class: "w-full border rounded px-2 py-1" %>
            </div>
            <div class="mb-4">
                <%= form.label :due, class: "block mb-1 font-semibold" %>
                <%= form.datetime_field :due, class: "w-full border rounded px-2 py-1" %>
            </div>
            <div class="flex justify-end gap-2">
                <%= form.submit "Create", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
                <button type="button" data-action="reminder-dialog#closeDialog" class="bg-gray-300 px-4 py-2 rounded hover:bg-gray-400">Cancel</button>
            </div>
        <% end %>
    </div>
</dialog>